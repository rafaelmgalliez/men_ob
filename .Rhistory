}
tibble(
variable = nm,
group = x$group %||% NA_character_,
label = x$label %||% nm,
description = x$description %||% NA_character_,
domain_type = x$domain_type %||% NA_character_,
values_raw = values_chr
)
})
list(
dataset = meta$dataset,
external_lookup_variables = meta$external_lookup_variables %||% character(0),
variables_tbl = vars_tbl,
raw = meta
)
}
`%||%` <- function(x, y) if (is.null(x)) y else x
# ------------------------------------------------------------
# 3. Converter string de domínio em vetor nomeado
#    Ex: "1=Sim;2=Não;9=Ignorado"
# ------------------------------------------------------------
parse_values_raw <- function(values_raw) {
if (is.na(values_raw) || !nzchar(values_raw)) return(NULL)
pieces <- str_split(values_raw, ";", simplify = FALSE)[[1]]
pieces <- str_trim(pieces)
pieces <- pieces[nzchar(pieces)]
out <- lapply(pieces, function(p) {
kv <- str_split_fixed(p, "=", 2)
key <- str_trim(kv[1])
val <- str_trim(kv[2])
c(key = key, val = val)
})
keys <- vapply(out, function(x) x["key"], character(1))
vals <- vapply(out, function(x) x["val"], character(1))
stats::setNames(vals, keys)
}
# ------------------------------------------------------------
# 4. Aplicar labels e recodificação automática
# ------------------------------------------------------------
apply_metadata_to_dataframe <- function(df, metadata_tbl) {
# Só trabalha com variáveis que existem no data.frame
metadata_tbl <- metadata_tbl %>%
filter(variable %in% names(df))
for (i in seq_len(nrow(metadata_tbl))) {
var_name <- metadata_tbl$variable[i]
var_label <- metadata_tbl$label[i]
domain_type <- metadata_tbl$domain_type[i]
values_raw <- metadata_tbl$values_raw[i]
# Aplicar label como atributo
attr(df[[var_name]], "label") <- var_label
# Recodificação automática apenas para domínios fechados
if (domain_type %in% c("closed_internal") && !is.na(values_raw)) {
map_vals <- parse_values_raw(values_raw)
if (!is.null(map_vals)) {
x_chr <- as.character(df[[var_name]])
# preserva valores não mapeados como estão
recoded <- ifelse(
x_chr %in% names(map_vals),
unname(map_vals[x_chr]),
x_chr
)
# se houver muitos NA reais, preserva
recoded[is.na(df[[var_name]])] <- NA_character_
# transforma em factor com níveis na ordem do YAML
df[[var_name]] <- factor(recoded, levels = unname(map_vals))
attr(df[[var_name]], "label") <- var_label
}
}
}
df
}
# ------------------------------------------------------------
# 5. Construir lista de labels para gtsummary
# ------------------------------------------------------------
build_gtsummary_labels <- function(df, metadata_tbl, vars) {
metadata_tbl %>%
filter(variable %in% vars, variable %in% names(df)) %>%
transmute(expr = paste0(variable, ' ~ "', label, '"')) %>%
pull(expr)
}
# ------------------------------------------------------------
# 2. Ler YAML e transformar em tibble de metadados
# ------------------------------------------------------------
read_metadata_yaml <- function(yaml_path) {
meta <- yaml::read_yaml(yaml_path)
vars_list <- meta$variables
if (is.null(vars_list) || length(vars_list) == 0) {
stop("O YAML não contém a chave 'variables' ou ela está vazia.")
}
vars_tbl <- purrr::imap_dfr(vars_list, function(x, nm) {
values_list <- x$values
values_chr <- NA_character_
if (!is.null(values_list)) {
# Converte lista nomeada em string "1=Sim;2=Não;9=Ignorado"
values_chr <- paste(
paste0(names(values_list), "=", unlist(values_list)),
collapse = ";"
)
}
tibble(
variable = nm,
group = x$group %||% NA_character_,
label = x$label %||% nm,
description = x$description %||% NA_character_,
domain_type = x$domain_type %||% NA_character_,
values_raw = values_chr
)
})
list(
dataset = meta$dataset,
external_lookup_variables = meta$external_lookup_variables %||% character(0),
variables_tbl = vars_tbl,
raw = meta
)
}
`%||%` <- function(x, y) if (is.null(x)) y else x
# ------------------------------------------------------------
# 3. Converter string de domínio em vetor nomeado
#    Ex: "1=Sim;2=Não;9=Ignorado"
# ------------------------------------------------------------
parse_values_raw <- function(values_raw) {
if (is.na(values_raw) || !nzchar(values_raw)) return(NULL)
pieces <- str_split(values_raw, ";", simplify = FALSE)[[1]]
pieces <- str_trim(pieces)
pieces <- pieces[nzchar(pieces)]
out <- lapply(pieces, function(p) {
kv <- str_split_fixed(p, "=", 2)
key <- str_trim(kv[1])
val <- str_trim(kv[2])
c(key = key, val = val)
})
keys <- vapply(out, function(x) x["key"], character(1))
vals <- vapply(out, function(x) x["val"], character(1))
stats::setNames(vals, keys)
}
# ------------------------------------------------------------
# 4. Aplicar labels e recodificação automática
# ------------------------------------------------------------
apply_metadata_to_dataframe <- function(df, metadata_tbl) {
# Só trabalha com variáveis que existem no data.frame
metadata_tbl <- metadata_tbl %>%
filter(variable %in% names(df))
for (i in seq_len(nrow(metadata_tbl))) {
var_name <- metadata_tbl$variable[i]
var_label <- metadata_tbl$label[i]
domain_type <- metadata_tbl$domain_type[i]
values_raw <- metadata_tbl$values_raw[i]
# Aplicar label como atributo
attr(df[[var_name]], "label") <- var_label
# Recodificação automática apenas para domínios fechados
if (domain_type %in% c("closed_internal") && !is.na(values_raw)) {
map_vals <- parse_values_raw(values_raw)
if (!is.null(map_vals)) {
x_chr <- as.character(df[[var_name]])
# preserva valores não mapeados como estão
recoded <- ifelse(
x_chr %in% names(map_vals),
unname(map_vals[x_chr]),
x_chr
)
# se houver muitos NA reais, preserva
recoded[is.na(df[[var_name]])] <- NA_character_
# transforma em factor com níveis na ordem do YAML
df[[var_name]] <- factor(recoded, levels = unname(map_vals))
attr(df[[var_name]], "label") <- var_label
}
}
}
df
}
# ------------------------------------------------------------
# 5. Construir lista de labels para gtsummary
# ------------------------------------------------------------
build_gtsummary_labels <- function(df, metadata_tbl, vars) {
metadata_tbl %>%
filter(variable %in% vars, variable %in% names(df)) %>%
transmute(expr = paste0(variable, ' ~ "', label, '"')) %>%
pull(expr)
}
# ------------------------------------------------------------
# 6. Selecionar variáveis por grupo do YAML
# ------------------------------------------------------------
select_vars_by_group <- function(metadata_tbl, groups) {
metadata_tbl %>%
filter(group %in% groups) %>%
pull(variable) %>%
unique()
}
# ------------------------------------------------------------
# 7. Gerar tabela descritiva principal
# ------------------------------------------------------------
generate_tbl_summary <- function(df,
metadata_tbl,
vars,
by = NULL,
missing = "ifany") {
vars <- vars[vars %in% names(df)]
if (length(vars) == 0) stop("Nenhuma variável válida para tabela descritiva.")
label_list_chr <- build_gtsummary_labels(df, metadata_tbl, vars)
label_list <- lapply(label_list_chr, function(x) eval(parse(text = x)))
tab_df <- df %>% select(all_of(c(vars, by)[!is.na(c(vars, by))]))
tbl <- gtsummary::tbl_summary(
data = tab_df,
by = by,
label = label_list,
missing = missing,
statistic = list(
all_continuous() ~ "{median} ({p25}, {p75})",
all_categorical() ~ "{n} ({p}%)"
),
digits = all_continuous() ~ 1
) %>%
gtsummary::bold_labels()
tbl
}
# ------------------------------------------------------------
# 8. Função de alto nível para o projeto
# ------------------------------------------------------------
run_meningite_descriptive_tables <- function(
parquet_path = NULL,
yaml_path = NULL,
groups = c("paciente", "clinica", "atendimento", "classificacao", "desfecho"),
by = NULL,
output_html = NULL) {
root <- find_project_root()
if (is.null(parquet_path)) {
parquet_path <- file.path(root, "datalake", "sinan", "meningite_br.parquet")
}
if (is.null(yaml_path)) {
yaml_path <- file.path(root, "metadados", "sinan_meningite_metadata.yaml")
}
message("Raiz do projeto: ", root)
message("Lendo Parquet: ", parquet_path)
message("Lendo YAML: ", yaml_path)
df <- arrow::read_parquet(parquet_path) %>% as.data.frame()
meta_obj <- read_metadata_yaml(yaml_path)
metadata_tbl <- meta_obj$variables_tbl
df <- apply_metadata_to_dataframe(df, metadata_tbl)
vars <- select_vars_by_group(metadata_tbl, groups)
# Remove possíveis variáveis técnicas ou de alta cardinalidade que não ficam bem em tabela descritiva
vars <- setdiff(vars, c(
"CLI_ESPECI", "ANT_OU_DE", "ANT_OUTR_D",
"NU_LOTE_V", "NU_LOTE_H", "NU_LOTE_I",
"NDUPLIC_N", "CS_FLXRET", "FLXRECEBI", "MIGRADO_W"
))
# Remover o by das variáveis principais se ele estiver duplicado
if (!is.null(by)) {
vars <- setdiff(vars, by)
}
tbl <- generate_tbl_summary(
df = df,
metadata_tbl = metadata_tbl,
vars = vars,
by = by
)
gt_tbl <- as_gt(tbl)
if (!is.null(output_html)) {
gt::gtsave(gt_tbl, output_html)
message("Tabela salva em: ", output_html)
}
list(
data = df,
metadata = metadata_tbl,
tbl = tbl,
gt = gt_tbl
)
}
# ------------------------------------------------------------
if (sys.nframe() == 0) {
res <- run_meningite_descriptive_tables(
by = "CLASSI_FIN",
output_html = "tabela_descritiva_meningite.html"
)
print(res$tbl)
}
if (sys.nframe() == 0) {
res <- run_meningite_descriptive_tables(
by = "CLASSI_FIN",
output_html = "tabela_descritiva_meningite.html"
)
print(res$tbl)
}
res <- run_meningite_descriptive_tables()
# ------------------------------------------------------------
# 1. Localizar raiz do projeto
# ------------------------------------------------------------
find_project_root <- function(start = ".") {
current <- normalizePath(start, winslash = "/", mustWork = TRUE)
repeat {
has_pyproject <- file.exists(file.path(current, "pyproject.toml"))
has_readme <- file.exists(file.path(current, "README.md"))
has_datalake <- dir.exists(file.path(current, "datalake"))
has_metadados <- dir.exists(file.path(current, "metadados"))
if ((has_pyproject || has_readme) && has_datalake && has_metadados) {
return(current)
}
parent <- dirname(current)
if (identical(parent, current)) {
stop("Não foi possível localizar a raiz do projeto Men_Ob.")
}
current <- parent
}
}
